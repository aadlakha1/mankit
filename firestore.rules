rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ORDERS: Anyone can create, only authenticated admin can read/update/delete
    match /orders/{orderId} {
      allow create: if
        // Must have required fields and nothing unexpected
        request.resource.data.keys().hasAll(['id', 'customer', 'items', 'total', 'status', 'createdAt'])
        && request.resource.data.keys().hasOnly(['id', 'customer', 'items', 'total', 'status', 'createdAt', 'notes'])
        // ID must match the document ID and the app's generated format
        && request.resource.data.id == orderId
        && orderId.matches('MK-[A-Z0-9]{6,20}')
        // Total must be positive number
        && request.resource.data.total is number
        && request.resource.data.total > 0
        // Status must be 'pending' on creation
        && request.resource.data.status == 'pending'
        // Items must be a list with at least 1 item
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        // Customer must have required fields and nothing unexpected
        && request.resource.data.customer.keys().hasAll(['firstName', 'lastName', 'email', 'phone', 'address', 'city', 'state', 'zip', 'country'])
        && request.resource.data.customer.keys().hasOnly(['firstName', 'lastName', 'email', 'phone', 'address', 'city', 'state', 'zip', 'country'])
        && request.resource.data.customer.email is string
        && request.resource.data.customer.email.size() <= 100
        // Notes optional, but bounded
        && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() <= 500))
        // Prevent absurdly large orders (anti-abuse)
        && request.resource.data.items.size() <= 20
        // Limit total to $10,000 (anti-abuse)
        && request.resource.data.total <= 10000;

      allow read, update, delete: if request.auth != null;
    }

    // WAITLIST: Anyone can create, only authenticated admin can read
    match /waitlist/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['email', 'createdAt'])
        && request.resource.data.keys().hasOnly(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 100
        && request.resource.data.email.matches('.+@.+[.].+');

      allow read: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
